# ─── Docker Compose — host port mappings ──────────────────────────────────────
# These control which ports are exposed on your machine.
MONGO_PORT=27017
REDIS_PORT=6379
PORT=3001
FRONTEND_PORT=3000

# ─── Backend ──────────────────────────────────────────────────────────────────
# Ignored when running inside Docker Compose (values are set directly in the
# compose file using the Docker network hostnames).
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/casecellshop
REDIS_HOST=localhost

# ─── ERP Simulation ───────────────────────────────────────────────────────────
# ERP_FAILURE_MODE: never | always | rate
ERP_FAILURE_MODE=never
ERP_LATENCY_MS=500
ERP_TIMEOUT_MS=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Baked into the client bundle at build time by Docker (ARG NEXT_PUBLIC_API_URL).
# Change this if you expose the backend on a different host or port.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
